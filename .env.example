# ===== AI Layer (OpenRouter) =====
# OpenRouter API key. Leave empty to use deterministic rule-based allocations (demo never breaks).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model id (OpenRouter format). Default: openai/gpt-4o-mini (cheap, JSON-reliable).
# Examples: anthropic/claude-3.5-sonnet, google/gemini-2.0-flash-001
OPENROUTER_MODEL=openai/gpt-4o-mini

# ===== Market Data =====
# CoinMarketCap API key. Leave empty to use mock market data (demo never breaks).
CMC_API_KEY=
# Use CMC sandbox base url for testing: https://sandbox-api.coinmarketcap.com
CMC_BASE_URL=https://pro-api.coinmarketcap.com

# ===== Wallet / Chain =====
# WalletConnect project id (optional, for WalletConnect connector). Get one at https://cloud.reown.com
NEXT_PUBLIC_WC_PROJECT_ID=
# Target chain: "bsc" (mainnet, id 56) or "bscTestnet" (id 97)
NEXT_PUBLIC_CHAIN=bsc

# ===== Execution — Trust Wallet Agent Kit (server-side only) =====
# "simulated" (default, demo-safe) or "live" (real swaps via the `twak` CLI)
WALLET_EXECUTION_MODE=simulated
# TWAK API credentials — get them at https://portal.trustwallet.com
# (one-time: `twak init` saves these to ~/.twak/credentials.json)
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
# Password for the agent wallet created via `twak wallet create` (live mode only).
TWAK_WALLET_PASSWORD=
# Optional: path to the twak binary if not on the server PATH (default: "twak")
# TWAK_BIN=

# ===== Autonomous agent worker (`pnpm worker`) =====
# Propose-only unless AGENT_AUTO_EXECUTE=true. Defaults shown.
AGENT_CAPITAL=10000
AGENT_RISK=moderate
AGENT_INTERVAL=1h               # 1h | 30m | 300s
AGENT_DRIFT_THRESHOLD=5         # only rebalance when max weight drift >= this %
AGENT_AUTO_EXECUTE=false        # true = execute real swaps (needs live wallet + funds)
# Trade the wallet's real on-chain holdings (via twak) instead of AGENT_CAPITAL.
# Defaults to AGENT_AUTO_EXECUTE; set explicitly to override.
# AGENT_USE_REAL_BALANCES=true
# AGENT_LOG_PATH=data/agent-log.jsonl
